<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress verbose provider logs during benchmarks -->
    <logger name="dev.sieve.ingest" level="WARN"/>
    <logger name="dev.sieve.match" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
